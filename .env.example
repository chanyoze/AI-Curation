# NewsLens 환경변수 예시 — 복사해서 .env 로 쓰고 실제 값 채운다. (.env 는 커밋 금지)

# Gemini (Google AI Studio 무료 티어 키 — https://aistudio.google.com/apikey)
# project-id/location 을 application.yml 에 넣지 말 것(넣으면 Vertex 유료 전환).
GEMINI_API_KEY=

# The Guardian Content API 키 (https://open-platform.theguardian.com/access/)
GUARDIAN_API_KEY=

# DB / Redis (compose.yaml 기본값과 일치 — 로컬은 그대로 둬도 됨)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=newslens
DB_USERNAME=newslens
DB_PASSWORD=newslens
REDIS_HOST=localhost
REDIS_PORT=6379
